\begin{Verbatim}[commandchars=\\\{\}]
\PYG{n}{n\PYGZus{}bins} \PYG{o}{=} \PYG{l+m+mi}{30}
\PYG{n}{counts}\PYG{p}{,} \PYG{n}{bins} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{histogram}\PYG{p}{(}\PYG{n}{samples}\PYG{p}{,} \PYG{n}{bins}\PYG{o}{=}\PYG{n}{n\PYGZus{}bins}\PYG{p}{)}
\PYG{n}{dx} \PYG{o}{=} \PYG{l+m+mi}{2} \PYG{o}{/} \PYG{n}{n\PYGZus{}bins}
\PYG{n}{pmf} \PYG{o}{=} \PYG{n}{counts} \PYG{o}{/} \PYG{n+nb}{sum}\PYG{p}{(}\PYG{n}{counts}\PYG{p}{)} \PYG{o}{/} \PYG{n}{dx}
\PYG{n}{midpoints} \PYG{o}{=} \PYG{p}{(}\PYG{n}{bins}\PYG{p}{[:}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1}\PYG{p}{]} \PYG{o}{+} \PYG{n}{bins}\PYG{p}{[}\PYG{l+m+mi}{1}\PYG{p}{:])} \PYG{o}{/} \PYG{l+m+mi}{2}
\end{Verbatim}
